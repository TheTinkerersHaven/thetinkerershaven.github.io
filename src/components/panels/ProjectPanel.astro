---
import PanelLayout from "../wrappers/PanelLayout.astro";
---

<PanelLayout data-panel="3">
    <h2 class="fade-in" style="--delay: 0.1s">My projects</h2>
    <p class="fade-in" style="--delay: 0.2s">These are some of the projects I've worked on:</p>
    <div class="fade-in" id="projects" style="--delay: 0.3s">
        <table>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Made for</th>
                <th>Using</th>
            </tr>
            <tr>
                <td>
                    <a href="https://github.com/TheTinkerersHaven/thetinkerershaven.github.io"
                        >thetinkerershaven.github.io</a
                    >
                </td>
                <td>This exact website! First written in Svelte, and then remade into what it is now.</td>
                <td>Myself</td>
                <td style="color: #ff5d01; font-weight: 600">Astro</td>
            </tr>
            <tr>
                <td><a href="https://github.com/PlanckTeam/Space4Arch">Space4Arch</a></td>
                <td>
                    Archeology app, innovation project for Planck Team (FIRST Lego League 2025-2026) (in collaboration
                    with
                    <span class="tooltip"
                        ><a href="https://github.com/Fleny113">@Fleny113</a
                        ><span class="tooltiptext">cool guy</span></span
                    >)
                </td>
                <td>Planck Team</td>
                <td style="color: #06d1f2; font-weight: 600">Expo (React Native)</td>
            </tr>
            <tr>
                <td><a href="https://github.com/PlanckTeam/planckteam.github.io">planckteam.github.io</a></td>
                <td>Website for Planck Team (FIRST Lego League & FIRST Tech Challenge)</td>
                <td>Planck Team</td>
                <td style="color: #ff5d01; font-weight: 600">Astro</td>
            </tr>
            <tr>
                <td><a href="https://github.com/TheTinkerersHaven/TerraLevel">TerraLevel</a></td>
                <td>Platformer tower-climb game made for Hack Club Daydream.</td>
                <td>Hack Club Daydream</td>
                <td style="color: #5a9fd0; font-weight: 600">Godot</td>
            </tr>
            <tr>
                <td><a href="https://github.com/TheTinkerersHaven/SpinKeys-Hackpad">SpinKeys</a></td>
                <td>5-key hackpad with two dials made for Hack Club Blueprint.</td>
                <td>Hack Club Blueprint</td>
                <td>
                    <span style="color: #3dd4c0; font-weight: 600">KiCad</span>,
                    <span style="color: #c084fc; font-weight: 600">Vial</span>
                </td>
            </tr>
            <tr>
                <td><a href="https://github.com/TheTinkerersHaven/CitySim">CitySim</a></td>
                <td>
                    Simple TUI-based city simulator (in collaboration with
                    <span class="tooltip"
                        ><a href="https://github.com/Fleny113">@Fleny113</a
                        ><span class="tooltiptext">cool guy pt.2</span></span
                    >)
                </td>
                <td>School</td>
                <td style="color: #6aafff; font-weight: 600">C++</td>
            </tr>
            <tr>
                <td>
                    <a href="https://github.com/TheTinkerersHaven/RestaurantSimulator26">Restaurant Simulator 26</a>
                </td>
                <td>
                    Java Swing-based GUI restaurant simulator (in collaboration with
                    <span class="tooltip"
                        ><a href="https://github.com/Fleny113">@Fleny113</a
                        ><span class="tooltiptext">did i already tell you he's a cool guy?</span></span
                    >)
                </td>
                <td>School</td>
                <td style="color: #ff9724; font-weight: 600">Java</td>
            </tr>
        </table>
    </div>
</PanelLayout>

<style>
    :root {
        --table-border-color: #ffffff50;
    }

    .fade-in {
        opacity: 0;
        filter: blur(6px);
        transform: translateY(30px);
    }

    .fade-in.visible {
        animation: projectFadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) var(--delay) both;
    }

    @keyframes projectFadeIn {
        from {
            opacity: 0;
            filter: blur(6px);
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            filter: blur(0);
            transform: translateY(0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .fade-in {
            opacity: 1;
            filter: none;
            transform: none;
        }
        .fade-in.visible {
            animation: none;
        }
    }

    table {
        width: 100%;
        max-width: 65vw;
        margin: 0 auto;
        border-collapse: separate;
        border-spacing: 0;
        font-family: var(--font-paragraph), sans-serif;
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        text-wrap: balance;
    }

    th,
    td {
        padding: 0.75rem 1rem;
        border: 5px solid var(--table-border-color);
        border-right: none;
        border-bottom: none;
    }

    th:first-child {
        border-top-left-radius: 12px;
    }
    th:last-child {
        border-top-right-radius: 12px;
    }
    th:last-child,
    td:last-child {
        border-right: 5px solid var(--table-border-color);
    }

    tr:last-child td:first-child {
        border-bottom-left-radius: 12px;
    }
    tr:last-child td:last-child {
        border-bottom-right-radius: 12px;
    }
    tr:last-child th,
    tr:last-child td {
        border-bottom: 5px solid var(--table-border-color);
    }

    #projects {
        overflow-x: auto;
    }

    @media (max-width: 1245px) {
        table {
            max-width: 100%;
        }

        tr:first-child {
            display: none;
        }

        tr {
            display: block;
            margin-bottom: 1rem;
            border: 1px solid var(--table-border-color);
            border-radius: 12px;
            overflow: hidden;
        }

        td {
            display: block;
            padding: 0.6rem 0.75rem;
            border: none;
            text-align: left;
            font-size: 0.9rem;
            border-bottom: 1px solid var(--table-border-color);
        }

        /* td:not(:last-child) {
                        border-bottom: 1px solid var(--table-border-color);
                    } */

        td::before {
            display: block;
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 0.15rem;
        }

        td:nth-child(1)::before {
            content: "Name";
        }
        td:nth-child(2)::before {
            content: "Description";
        }
        td:nth-child(3)::before {
            content: "Made for";
        }
        td:nth-child(4)::before {
            content: "Using";
        }

        td:last-child {
            border-right: none;
            border-bottom: none;
        }

        tr:last-child td {
            border-bottom: 1px solid var(--table-border-color);
        }

        tr:last-child td:last-child {
            border-bottom: none;
        }
    }
</style>
