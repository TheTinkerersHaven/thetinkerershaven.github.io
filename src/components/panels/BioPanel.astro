---
import { Picture } from "astro:assets";

import ProfilePic from "../../assets/profilepic.jpg";
import PanelLayout from "../wrappers/PanelLayout.astro";
---

<PanelLayout data-panel="2" id="bio">
    <div class="fade-in" style="--delay: 0.1s">
        <Picture
            src={ProfilePic}
            alt="Greg PFP"
            formats={['avif', 'webp']}
            widths={[300, 400, 500, 600, 700, 800, 900, 1000, ProfilePic.width]}
            sizes={`(max-width: 768px) 100vw, 800px`}
        />
    </div>
    <h2 class="fade-in" style="--delay: 0.1s">About myself</h2>
    <p class="fade-in" style="--delay: 0.2s">
        Hi! I’m Greg, a Computer Science student with a passion for all things tech.
    </p>
    <p class="fade-in" style="--delay: 0.3s">
        My happy place is a mix of
        <span class="tooltip">hobbyist electronics<span class="tooltiptext">real electronics are scary</span></span>
        and 3D printing; there’s just something satisfying about seeing a project come to life!
    </p>
    <p class="fade-in" style="--delay: 0.4s">
        I’m also a proud <span class="tooltip">furry<span class="tooltiptext">:3</span></span>, a huge fan of
        <span class="tooltip"
            >Murder Drones<span class="tooltiptext"
                >if you couldn't tell from the pfp, also we need a second season Liam</span
            ></span
        >, and an
        <a href="https://twolenstales.altervista.org" target="_blank" rel="noopener noreferrer"
            >amateur photographer</a
        >.
    </p>
    <p class="fade-in" style="--delay: 0.5s">
        I love exploring the intersection of art and technology, and I'm glad you're here to see what I'm working on.
    </p>
    <p class="fade-in" style="--delay: 0.6s">
        You can find me around as
        <span class="tooltip">TheTinkerersHaven<span class="tooltiptext">serious stuff</span></span>
        or
        <span class="tooltip">Greg7327<span class="tooltiptext">gaming stuff</span></span>, usually.
    </p>
</PanelLayout>

<style>
    img {
        aspect-ratio: 1;
        width: 50vw;
        max-width: 300px;
        height: auto;
        border-radius: 30px;
    }

    .fade-in {
        opacity: 0;
        filter: blur(6px);
        transform: translateY(30px);
    }

    .fade-in.visible {
        animation: bioFadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) var(--delay) both;
    }

    @keyframes bioFadeIn {
        from {
            opacity: 0;
            filter: blur(6px);
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            filter: blur(0);
            transform: translateY(0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .fade-in {
            opacity: 1;
            filter: none;
            transform: none;
        }
        .fade-in.visible {
            animation: none;
        }
    }
</style>
