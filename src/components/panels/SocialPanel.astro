---
import { Icon } from "astro-icon/components";
import PanelLayout from "../wrappers/PanelLayout.astro";
---

<PanelLayout data-panel="5">
    <h2 class="fade-in" style="--delay: 0.1s">Find me online</h2>
    <p class="fade-in" style="--delay: 0.2s">Reach out or follow my work on these platforms.</p>
    <div class="fade-in" style="--delay: 0.3s">
        <ul class="social-list">
            <li>
                <a
                    class="social-link"
                    href="https://github.com/TheTinkerersHaven"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <Icon name="mdi:github" class="social-icon" aria-hidden="true" />
                    GitHub
                </a>
            </li>
            <li>
                <a
                    class="social-link"
                    href="https://www.youtube.com/@tinkerershaven"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <Icon name="mdi:youtube" class="social-icon" aria-hidden="true" />
                    YouTube
                </a>
            </li>
        </ul>
    </div>
</PanelLayout>

<style>
    .fade-in {
        opacity: 0;
        filter: blur(6px);
        transform: translateY(30px);
    }

    .fade-in.visible {
        animation: socialFadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) var(--delay) both;
    }

    @keyframes socialFadeIn {
        from {
            opacity: 0;
            filter: blur(6px);
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            filter: blur(0);
            transform: translateY(0);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .fade-in {
            opacity: 1;
            filter: none;
            transform: none;
        }
        .fade-in.visible {
            animation: none;
        }
    }

    .social-list {
        --link-color: white;
        list-style: none;
        padding: 0;
        margin: 1.25rem 0 0;
        display: grid;
        gap: 0.75rem;
    }

    .social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
        text-decoration: none;
    }

    .social-icon {
        width: 1.3rem;
        height: 1.3rem;
    }
</style>
