---
import bgloop from "../../assets/bgloop.mp4";
---

<video class="bg-video" autoplay muted loop playsinline aria-hidden>
    <source src={bgloop} type="video/mp4">
</video>
<div class="center-container">
    <div class="welcome-tile">
        <h1>The Tinkerer's Website</h1>
        <p>Have a look inside.</p>
        <button type="button" onclick="window.location.href='#bio'">Jump in</button>
    </div>
</div>

<script>
    const video = document.querySelector<HTMLVideoElement>(".bg-video");
    if (video) {
        if (video.readyState >= 2) {
            video.classList.add("video-ready");
        } else {
            video.addEventListener(
                "loadeddata",
                () => {
                    video.classList.add("video-ready");
                },
                { once: true },
            );
        }
    }
</script>

<style>
    .bg-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
        opacity: 0;
        filter: blur(12px);
        transition:
            opacity 900ms ease,
            filter 1200ms ease;
    }

    .bg-video.video-ready {
        opacity: 1;
        filter: blur(0);
    }

    .center-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .welcome-tile {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 2rem;
        border-radius: 12px;
        color: white;
        max-width: min(92vw, 920px);
        z-index: 1;
        opacity: 0;
        animation: fadeInUp 800ms ease 1.2s forwards;

        h1 {
            margin: 10px 0 0 0;
            font-size: clamp(2.5rem, 6.5vw, 6rem);
            font-family: var(--font-title), sans-serif;
            line-height: 1.05;
        }

        p {
            font-family: var(--font-paragraph), sans-serif;
            font-size: clamp(1rem, 2.5vw, 1.25rem);
        }

        button {
            padding: 0.6rem 1rem;
            border: 0;
            border-radius: 8px;
            background: #0ea5e9;
            color: white;
            font-weight: 600;
            cursor: pointer;

            &:hover {
                background: #0284c7;
            }
        }
    }
</style>

<style is:global>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
